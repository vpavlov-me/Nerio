{
  "schemaVersion": 1,
  "project": "Nerio",
  "runtimeAxes": {
    "theme": ["purple", "blue", "green", "orange", "red", "neutral"],
    "mode": ["system", "light", "dark"],
    "density": ["comfortable", "compact"]
  },
  "tokenCustomizableValues": [
    "font",
    "radius",
    "motion",
    "spacing",
    "shadow/elevation",
    "contrast"
  ],
  "futureRuntimeAxes": ["radius", "font", "motion", "contrast", "scale"],
  "runtimeAxisPolicy": {
    "v1": "Only theme, mode, and density are runtime appearance axes in v1.",
    "notAllowedInV1": ["data-font", "data-radius", "data-motion", "data-contrast", "data-scale"],
    "description": "Font, radius, motion, spacing, shadow/elevation, and contrast are token-customizable through CSS variables in v1, but they are not separate runtime axes."
  },
  "customThemeSupport": {
    "enabled": true,
    "description": "Product teams may add custom data-theme values by overriding the same semantic and component CSS variables. Custom themes must still use the shared data-mode and data-density axes."
  },
  "defaultRuntimeAttributes": {
    "data-theme": "purple",
    "data-mode": "system",
    "data-density": "comfortable"
  },
  "statusValues": {
    "planned": "Approved for the tier, not implemented yet.",
    "implemented-initial": "First implementation exists, and API or styling may still change.",
    "quality-pass-needed": "Component exists but still needs an API, accessibility, token, docs, and registry review before it can support Pro work.",
    "stable-core": "Component passed the Core quality checklist and can safely support future Pro components, templates, registry installs, and AI/MCP usage.",
    "future": "Expected later, not part of the first Core milestone."
  },
  "tiers": {
    "core": {
      "name": "Nerio Core",
      "description": "Open-source foundation, tokens, brand themes, modes, density, token-customizable appearance values, primitive and base UI components, public docs, public registry, CLI, and public MCP/component discovery."
    },
    "pro": {
      "name": "Nerio Pro",
      "description": "Paid advanced product components, templates, premium brand themes, Figma assets, advanced registry items, and Pro MCP/AI tooling."
    }
  },
  "rule": "Core = building blocks. Pro = product-ready solutions.",
