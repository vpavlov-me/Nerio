{
  "name": "@nerio-ui/adapters",
  "version": "0.1.0-alpha.1",
  "description": "Responsibility-scoped Nerio Core adapters for icons, tables, charts, forms, and schemas.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vpavlov-me/Nerio.git",
    "directory": "packages/adapters"
  },
  "homepage": "https://nerio.vpavlov.com/docs/foundations/icons",
  "bugs": {
    "url": "https://github.com/vpavlov-me/Nerio/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "exports": {
    "./icons": {
      "types": "./src/icons.ts",
      "default": "./src/icons.ts"
    },
    "./table": {
      "types": "./src/table.ts",
      "default": "./src/table.ts"
    },
    "./charts": {
      "types": "./src/charts.ts",
      "default": "./src/charts.ts"
    },
    "./forms": {
      "types": "./src/forms.ts",
      "default": "./src/forms.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./motion": {
      "types": "./src/motion.tsx",
      "default": "./src/motion.tsx"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "test:motion": "vitest run test/motion.test.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.561.0"
  },
  "devDependencies": {
    "@nerio-ui/config": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.2",
    "jsdom": "29.1.1",
    "motion": "12.42.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "recharts": "^3.6.0",
    "typescript": "^7.0.2",
    "vitest": "4.1.10",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.21.3",
    "motion": "^12.42.2",
    "react": ">=19",
    "react-hook-form": "^7.82.0",
    "recharts": "^3.6.0",
    "zod": "^4.2.1"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-table": {
      "optional": true
    },
    "motion": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
