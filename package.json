{
  "name": "nerio",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "build": "turbo build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:branch-policy": "node --test scripts/check-branch-policy.test.mjs",
    "validate:catalog": "node scripts/validate-component-catalog.mjs",
    "test:catalog": "node --test scripts/validate-component-catalog.test.mjs scripts/validate-release-docs.test.mjs",
    "validate:tokens": "node scripts/validate-tokens.mjs",
    "test:tokens": "node --test scripts/validate-tokens.test.mjs scripts/validate-runtime-axes.test.mjs",
    "validate:runtime-axes": "node scripts/validate-runtime-axes.mjs",
    "validate:docs": "pnpm --filter @nerio-ui/docs validate:docs",
    "validate:typography": "node scripts/validate-typography.mjs",
    "validate:release": "pnpm test:catalog && pnpm test:tokens && node scripts/validate-release-docs.mjs && node scripts/release-smoke.mjs",
    "test:cli": "pnpm --filter @nerio-ui/cli test:fixture",
    "test:mcp": "pnpm --filter @nerio-ui/mcp test:fixture",
    "test:adapters": "node scripts/adapter-consumer-smoke.mjs && pnpm test:motion-adapter",
    "test:motion-adapter": "pnpm --filter @nerio-ui/adapters test:motion && node scripts/validate-motion-adapter.mjs",
    "test:browser": "playwright test",
    "test:visual": "playwright test --config playwright.visual.config.mjs",
    "test:visual:update": "playwright test --config playwright.visual.config.mjs --update-snapshots",
    "test:docs-examples": "tsc -p apps/docs/fixtures/docs-examples/tsconfig.json",
    "test:ui": "pnpm --filter @nerio-ui/ui test",
    "test:a11y": "pnpm --filter @nerio-ui/ui test:a11y",
    "pack:check": "node scripts/pack-check.mjs"
  },
  "devDependencies": {
    "@nerio-ui/config": "workspace:*",
    "@playwright/test": "1.55.1",
    "esbuild": "0.28.1",
    "prettier": "^3.7.4",
    "turbo": "^2.10.3",
    "typescript": "^5.9.3"
  }
}
