{
  "name": "nerio",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "build": "turbo build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "validate:docs": "pnpm --filter @nerio/docs validate:docs",
    "test:cli": "pnpm --filter @nerio/cli test:fixture",
    "test:mcp": "pnpm --filter @nerio/mcp test:fixture",
    "test:ui": "pnpm --filter @nerio/ui test",
    "test:a11y": "pnpm --filter @nerio/ui test:a11y",
    "pack:check": "node scripts/pack-check.mjs"
  },
  "devDependencies": {
    "@nerio/config": "workspace:*",
    "prettier": "^3.7.4",
    "turbo": "^2.10.3",
    "typescript": "^5.9.3"
  }
}
